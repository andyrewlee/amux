#!/usr/bin/env bash
set -euo pipefail

if [[ -n "${MEDUSA_SKIP_HARNESS:-}" ]]; then
  echo "medusa pre-push: skipping harness (MEDUSA_SKIP_HARNESS set)"
  exit 0
fi

root="$(git rev-parse --show-toplevel)"
cd "$root"

monitor_args=(${MEDUSA_HARNESS_MONITOR_ARGS:---mode=monitor --tabs=24 --frames=200 --warmup=20 --hot-tabs=1 --payload-bytes=128})
center_args=(${MEDUSA_HARNESS_CENTER_ARGS:---mode=center --tabs=8 --frames=200 --warmup=20 --hot-tabs=1 --payload-bytes=128})

echo "medusa pre-push: running headless UI harness (monitor)..."
go run ./cmd/medusa-harness "${monitor_args[@]}"

echo "medusa pre-push: running headless UI harness (center)..."
go run ./cmd/medusa-harness "${center_args[@]}"

echo "medusa pre-push: running headless UI snapshots..."
go test ./internal/e2e
